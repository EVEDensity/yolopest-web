# ============================================================
# Yolo-Pest 环境变量模板
# 复制为 .env 并填入实际值
# docker compose -f docker-compose.deploy.yml up -d
# ============================================================

# ── 模型 ──
MODEL_PATH=/app/model_weights/best.pt
IMG_SIZE=640
CONF_THRESH=0.5
DEBUG=False

# ── 数据库 ──
POSTGRES_USER=yolopest
POSTGRES_PASSWORD=请修改为强密码
POSTGRES_DB=yolopest
# 以下由 docker-compose 自动注入容器间通信地址，不用改

# ── JWT ──
SECRET_KEY=请修改为随机长字符串
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── DeepSeek AI ──
DEEPSEEK_API_KEY=sk-你的key

# ── 静态文件访问 ──
# 不设置或留空：图片URL用相对路径 /api/static/...（nginx反代，Web端用）
# 设置了值：图片URL用 http(s)://xxx/api/static/...（微信小程序需要完整URL）
API_BASE_URL=

# ── 可选：自定义镜像 ──
# FRONTEND_IMAGE=yolopest/frontend:latest
# BACKEND_IMAGE=yolopest/backend:latest
